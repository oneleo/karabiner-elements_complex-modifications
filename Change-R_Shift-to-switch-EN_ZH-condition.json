{
  "description": "Cursor: Change R_Shift to switch EN/ZH condition",
  "manipulators": [
    {
      "conditions": [
        {
          "input_sources": [
            {
              "input_source_id": "^com\\.apple\\.keylayout\\.ABC$",
              "language": "en*"
            }
          ],
          "type": "input_source_unless"
        }
      ],
      "from": {
        "key_code": "right_shift",
        "modifiers": { "optional": ["any"] }
      },
      "parameters": {
        "basic.to_if_alone_timeout_milliseconds": 200,
        "basic.to_if_held_down_threshold_milliseconds": 200
      },
      "to": [
        {
          "key_code": "right_shift",
          "lazy": true
        }
      ],
      "to_if_alone": [
        {
          "select_input_source": {
            "input_source_id": "^com\\.apple\\.keylayout\\.ABC$",
            "language": "en*"
          }
        }
      ],
      "to_if_held_down": [{ "key_code": "right_shift" }],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "input_sources": [
            {
              "input_source_id": "^com\\.boshiamy\\.inputmethod\\.BoshiamyIMK$",
              "language": "zh*"
            }
          ],
          "type": "input_source_unless"
        }
      ],
      "from": {
        "key_code": "right_shift",
        "modifiers": { "optional": ["any"] }
      },
      "parameters": {
        "basic.to_if_alone_timeout_milliseconds": 200,
        "basic.to_if_held_down_threshold_milliseconds": 200
      },
      "to": [
        {
          "key_code": "right_shift",
          "lazy": true
        }
      ],
      "to_if_alone": [
        {
          "hold_down_milliseconds": 1,
          "key_code": "spacebar",
          "modifiers": ["right_control", "right_option"]
        }
      ],
      "to_if_held_down": [{ "key_code": "right_shift" }],
      "type": "basic"
    }
  ]
}
